# Variáveis de ambiente — Painel Pessoal
# Copie este arquivo para .env.local e ajuste os valores

# ============================================
# Autenticação (obrigatório)
# ============================================
# Usuário e senha para acessar o painel
APP_USER=admin
APP_PASSWORD=troque_esta_senha_123

# Secret do NextAuth — gere com: openssl rand -base64 32
AUTH_SECRET=seu_secret_aleatorio_aqui

# URL base da aplicação
NEXTAUTH_URL=http://localhost:3000
